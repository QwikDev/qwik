# Qwik shared Codex command policy.
# This is Codex exec-policy, not natural-language AI guidance.

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Read-only Git status inspection is safe for Qwik repo work.",
    match = ["git status", "git status --short --branch"],
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Read-only Git diff inspection is safe for Qwik repo work.",
    match = ["git diff", "git diff --check", "git diff --cached --stat"],
)

prefix_rule(
    pattern = ["git", "log"],
    decision = "allow",
    justification = "Read-only Git history inspection is safe for Qwik repo work.",
    match = ["git log --oneline -5", "git log --stat"],
)

prefix_rule(
    pattern = ["git", "show"],
    decision = "allow",
    justification = "Read-only Git object inspection is safe for Qwik repo work.",
    match = ["git show --stat HEAD", "git show HEAD:README.md"],
)

prefix_rule(
    pattern = ["git", "rev-parse"],
    decision = "allow",
    justification = "Read-only Git revision inspection is safe for Qwik repo work.",
    match = ["git rev-parse --show-toplevel", "git rev-parse HEAD"],
)

prefix_rule(
    pattern = ["pnpm", "prettier", "--check"],
    decision = "allow",
    justification = "Prettier check mode verifies formatting without changing files.",
    match = ["pnpm prettier --check .ruler README.md .gitignore"],
    not_match = ["pnpm prettier --write ."],
)

prefix_rule(
    pattern = ["git", "add"],
    decision = "prompt",
    justification = "Staging files changes repository state and should be reviewed.",
    match = ["git add README.md", "git add .ruler/README.md"],
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "Creating commits changes repository history and should be reviewed.",
    match = ["git commit -m docs: update guidance"],
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing publishes branch changes and should be reviewed.",
    match = ["git push", "git push origin docs/ruler-ai-guidance-qwik"],
)

prefix_rule(
    pattern = ["npx", "@intellectronica/ruler"],
    decision = "prompt",
    justification = "npx can fetch packages and Ruler writes generated assistant outputs.",
    match = ["npx @intellectronica/ruler apply --agents codex"],
)

prefix_rule(
    pattern = ["ruler", "apply"],
    decision = "prompt",
    justification = "Ruler apply writes generated assistant outputs.",
    match = ["ruler apply", "ruler apply --agents codex"],
)

prefix_rule(
    pattern = ["git", "reset"],
    decision = "forbidden",
    justification = "Do not reset repo state from Codex; inspect diffs and ask before destructive recovery.",
    match = ["git reset --hard", "git reset --hard HEAD"],
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "forbidden",
    justification = "Do not delete untracked files from Codex; ask before destructive cleanup.",
    match = ["git clean -fd", "git clean -fdx"],
)

prefix_rule(
    pattern = ["rm"],
    decision = "forbidden",
    justification = "Use targeted file edits or ask before destructive deletion.",
    match = ["rm README.md", "rm -rf node_modules"],
)
