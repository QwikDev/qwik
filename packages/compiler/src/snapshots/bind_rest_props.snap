import { useSignal } from '@qwik.dev/core';

export function Field({ label, ...rest }) {
  return <label>{label}<input onInput$={() => console.log('input')} {...rest} /></label>;
}

export function App() {
  const value = useSignal('');
  return <Field label="Name" bind:value={value} />;
}

