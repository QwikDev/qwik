export function App() {
  const visible = useSignal(true);
  const label = useSignal('ready');
  const attrs = useSignal({ role: 'status' });
  return <div>{visible.value && <span {...attrs.value} title={`label ${label.value}`}>{label.value + '!'}</span>}</div>;
}

