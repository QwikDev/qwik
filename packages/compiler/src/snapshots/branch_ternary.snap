import { createSignal, _withCaptures, BranchRange, createBranch } from '@qwik.dev/core/spark';
import { component_branch_condition_segment_0 } from './component.tsx_component_branch_condition_segment_0';
import { component_branch_then_segment_1 } from './component.tsx_component_branch_then_segment_1';
import { component_branch_else_segment_2 } from './component.tsx_component_branch_else_segment_2';

export function App(_props, ctx) {
  const count = createSignal(0);
  const el0 = ctx.document.createElement('section');
  const fragment1 = ctx.document.createDocumentFragment();
  const comment2 = ctx.document.createComment('b');
  const comment3 = ctx.document.createComment('/b');
  fragment1.appendChild(comment2);
  fragment1.appendChild(comment3);
  const branch4 = createBranch(
    ctx,
    new BranchRange(ctx.document, comment2, comment3),
    _withCaptures(component_branch_condition_segment_0, [count]),
    _withCaptures(component_branch_then_segment_1, [count]),
    _withCaptures(component_branch_else_segment_2, [count])
  );
  ctx.scheduler.notify(branch4);
  el0.appendChild(fragment1);
  return [el0];
}

