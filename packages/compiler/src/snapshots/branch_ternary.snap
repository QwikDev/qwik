import { useSignal } from '@qwik.dev/core';
export function App() {
  const count = useSignal(0);
  return (
    <section>
      {count.value % 2 === 0 ? (
        <p className="even">Even {count.value}</p>
      ) : (
        <button onClick$={() => count.value++}>Odd {count.value}</button>
      )}
    </section>
  );
}

