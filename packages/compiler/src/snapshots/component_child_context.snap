import {
  createContext,
  createContextProvider,
  createSignal,
  createComponent,
  escapeHTML,
  renderSsrTextNode,
  createSsrElementTextTarget,
} from '@qwik.dev/core/spark';
import { Context } from './context';

export function Child(_props, ctx) {
  const value = createContext(Context);
  const id0 = ctx.nextId();
  ctx.addRoot(value);
  return (
    '<p q:id="' +
    id0 +
    '">' +
    escapeHTML(renderSsrTextNode(createSsrElementTextTarget(id0), value)) +
    '</p>'
  );
}
export function Parent(_props, ctx) {
  const value = createSignal('provided');
  createContextProvider(Context, value);
  const contextScopeId = ctx.contextScopeId();
  const contextHtml =
    '<section>' + createComponent({}, (props) => Child(props, ctx)) + '</section>';
  return '<!c=' + contextScopeId + '>' + contextHtml + '<!/c>';
}

