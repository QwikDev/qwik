import {
  useSignal,
  escapeHTML,
  createSsrElementTarget,
  renderSsrAttr,
  maybeThen,
} from '@qwik.dev/core/spark';

export function App(props, ctx) {
  const classes = useSignal('active');
  const id0 = ctx.nextId();
  const id1 = ctx.nextId();
  ctx.addRoot(classes);
  const attr0 = renderSsrAttr(createSsrElementTarget(id1), 'class', classes);
  return maybeThen(
    attr0,
    (attr0) =>
      '<main q:id="' +
      id0 +
      '"' +
      ' class="shell"' +
      '>' +
      '<button' +
      ' q:id="' +
      id1 +
      '"' +
      ' class="' +
      escapeHTML(attr0) +
      '"' +
      '>' +
      'Toggle' +
      '</button>' +
      '</main>'
  );
}
