  const firstContext = createContextId('first');
  const secondContext = createContextId('second');
  useContextProvider(firstContext, 'one');
  useContextProvider(secondContext, 2);
  return [
    createSsrRecord('<!c=', ctx.contextScopeRef(), '>'),
