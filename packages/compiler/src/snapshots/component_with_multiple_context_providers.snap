import { createContextId, useContextProvider } from '@qwik.dev/core/spark';

export function App(props, ctx) {
  const firstContext = createContextId('first');
  const secondContext = createContextId('second');
  useContextProvider(firstContext, 'one');
  useContextProvider(secondContext, 2);
  const contextScopeId = ctx.contextScopeId();
  return '<!c=' + contextScopeId + '>' + '<p>Provided</p>' + '<!/c>';
}
