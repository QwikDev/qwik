import { createSignal, createPropsEffect } from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const attrs = createSignal({
    title: 'from-spread',
    children: 'ignored',
    className: { active: true },
  });
  const title = createSignal('final');
  const el0 = ctx.document.createElement('div');
  const effect1 = createPropsEffect(
    el0,
    [],
    () => ({
      ...attrs.value,
      get title() {
        return title.value;
      },
      'data-id': 'static',
    }),
    { scheduler: ctx.scheduler }
  );
  ctx.scheduler.notify(effect1);
  const text2 = ctx.document.createTextNode('Child');
  el0.appendChild(text2);
  return [el0];
}

