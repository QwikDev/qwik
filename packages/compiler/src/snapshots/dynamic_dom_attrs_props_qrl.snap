import { createSignal, createAttrExpressionEffect } from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const count = createSignal(0);
  const el0 = ctx.document.createElement('div');
  const effect1 = createAttrExpressionEffect(el0, 'title', [], () => `count ${count.value}`, {
    scheduler: ctx.scheduler,
  });
  ctx.scheduler.notify(effect1);
  const effect2 = createAttrExpressionEffect(
    el0,
    'class',
    [],
    () => ({ active: count.value > 0 }),
    { scheduler: ctx.scheduler }
  );
  ctx.scheduler.notify(effect2);
  const effect3 = createAttrExpressionEffect(
    el0,
    'style',
    [],
    () => ({ color: count.value % 2 === 0 ? 'green' : 'blue' }),
    { scheduler: ctx.scheduler }
  );
  ctx.scheduler.notify(effect3);
  el0.setAttribute('data-kind', 'counter');
  const text4 = ctx.document.createTextNode('Attrs');
  el0.appendChild(text4);
  return [el0];
}

