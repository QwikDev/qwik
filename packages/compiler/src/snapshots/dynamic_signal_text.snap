import {
  createSignal,
  escapeHTML,
  renderSsrTextNode,
  createSsrElementTextTarget,
} from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const count = createSignal(0);
  const id0 = ctx.nextId();
  ctx.addRoot(count);
  return (
    '<p q:id="' +
    id0 +
    '">' +
    escapeHTML(renderSsrTextNode(createSsrElementTextTarget(id0), count)) +
    '</p>'
  );
}

