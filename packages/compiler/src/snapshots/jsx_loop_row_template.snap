import { createSignal, ForRange, createForBlock } from '@qwik.dev/core/spark';
import { component_for_key_segment_1 } from './component.tsx_component_for_key_segment_1';
import { component_for_render_segment_0 } from './component.tsx_component_for_render_segment_0';

export function App(_props, ctx) {
  const rows = createSignal([
    {
      id: 1,
      label: 'Alpha',
      selected: false,
    },
  ]);
  const el0 = ctx.document.createElement('table');
  const el1 = ctx.document.createElement('tbody');
  const fragment2 = ctx.document.createDocumentFragment();
  const comment3 = ctx.document.createComment('f');
  const comment4 = ctx.document.createComment('/f');
  fragment2.appendChild(comment3);
  fragment2.appendChild(comment4);
  const forBlock5 = createForBlock(
    ctx,
    new ForRange(ctx.document, comment3, comment4),
    rows,
    component_for_key_segment_1,
    component_for_render_segment_0,
    true,
    false
  );
  forBlock5.run();
  el1.appendChild(fragment2);
  el0.appendChild(el1);
  return el0;
}

