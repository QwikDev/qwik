import { createSignal } from '@qwik.dev/core/spark';
export function App() {
  const items = createSignal([{ id: 'a', label: 'Alpha' }]);
  return (
    <ul>
      {items.value.map((row, index) => (
        <li key={row.id} data-index={index}>
          {row.label}
        </li>
      ))}
    </ul>
  );
}

