import { createAttrExpressionEffect, createTextExpressionEffect } from '@qwik.dev/core/spark';
export const component_for_render_segment_0 = (ctx, row, index) => {
  const el0 = ctx.document.createElement('li');
  const effect1 = createAttrExpressionEffect(el0, 'data-index', [], () => index.value, {
    scheduler: ctx.scheduler,
  });
  effect1.run();
  const text2 = ctx.document.createTextNode('');
  const effect3 = createTextExpressionEffect(text2, [], () => row.value.label, {
    scheduler: ctx.scheduler,
  });
  effect3.run();
  el0.appendChild(text2);
  return [el0];
};

