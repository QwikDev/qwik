import { createSignal, ForRange, createForBlock } from '@qwik.dev/core/spark';
import { component_for_key_segment_1 } from './component.tsx_component_for_key_segment_1';
import { component_for_render_segment_0 } from './component.tsx_component_for_render_segment_0';

export function App(_props, ctx) {
  const items = createSignal([
    {
      id: 'a',
      label: 'Alpha',
    },
  ]);
  const el0 = ctx.document.createElement('ul');
  const fragment1 = ctx.document.createDocumentFragment();
  const comment2 = ctx.document.createComment('f');
  const comment3 = ctx.document.createComment('/f');
  fragment1.appendChild(comment2);
  fragment1.appendChild(comment3);
  const forBlock4 = createForBlock(
    ctx,
    new ForRange(ctx.document, comment2, comment3),
    items,
    component_for_key_segment_1,
    component_for_render_segment_0,
    true,
    true
  );
  forBlock4.run();
  el0.appendChild(fragment1);
  return [el0];
}

