  patchAttrValue,
} from '@qwik.dev/core/spark';

const dom_App_template0 = createTemplate('<div>Attrs</div>');
export function App(_props, ctx) {
  const title = createSignal('hello');
  const classes = createSignal('active');
  const style = createSignal('color:red');
  const fragment0 = dom_App_template0(ctx.document);
  const el1 = fragment0.firstChild;
  const effect2 = createDomBatchEffect(batch3, { scheduler: ctx.scheduler });
  function batch3() {
    patchAttrValue(el1, 'title', readTrackedSourceValue(title));
    patchAttrValue(el1, 'class', readTrackedSourceValue(classes));
