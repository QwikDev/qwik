import {
  createSignal,
  escapeHTML,
  createSsrElementTarget,
  renderSsrAttr,
  maybeThen,
  promiseAll,
} from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const title = createSignal('hello');
  const classes = createSignal('active');
  const style = createSignal('color:red');
  const id0 = ctx.nextId();
  ctx.addRoot(title);
  const attr1 = renderSsrAttr(createSsrElementTarget(id0), 'title', title);
  ctx.addRoot(classes);
  const attr2 = renderSsrAttr(createSsrElementTarget(id0), 'class', classes);
  ctx.addRoot(style);
  const attr3 = renderSsrAttr(createSsrElementTarget(id0), 'style', style);
  return maybeThen(
    promiseAll([attr1, attr2, attr3]),
    ([attr1, attr2, attr3]) =>
      '<div q:id="' +
      id0 +
      '" title="' +
      escapeHTML(attr1) +
      '" class="' +
      escapeHTML(attr2) +
      '" style="' +
      escapeHTML(attr3) +
      '">Attrs</div>'
  );
}

