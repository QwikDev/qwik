============================= src/component.tsx ==

import {
  createSignal,
  createAttrEffect,
  createClassEffect,
  createStyleEffect,
} from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const title = createSignal('hello');
  const classes = createSignal('active');
  const style = createSignal('color:red');
  const el0 = ctx.document.createElement('div');
  const effect1 = createAttrEffect(el0, 'title', title, { scheduler: ctx.scheduler });
  ctx.scheduler.notify(effect1);
  const effect2 = createClassEffect(el0, classes, { scheduler: ctx.scheduler });
  ctx.scheduler.notify(effect2);
  const effect3 = createStyleEffect(el0, style, { scheduler: ctx.scheduler });
  ctx.scheduler.notify(effect3);
  const text4 = ctx.document.createTextNode('Attrs');
  el0.appendChild(text4);
  return [el0];
}

