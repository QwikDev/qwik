import {
  createSignal,
  createSsrDomBatchEffect,
  createSsrElementTarget,
  escapeHTML,
  renderSsrAttr,
} from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const title = createSignal('hello');
  const classes = createSignal('active');
  const style = createSignal('color:red');
  const id0 = ctx.nextId();
  ctx.addRoot(title);
  const batch1 = createSsrDomBatchEffect();
  const attr2 = renderSsrAttr(createSsrElementTarget(id0), 'title', title, batch1);
  ctx.addRoot(classes);
  const attr3 = renderSsrAttr(createSsrElementTarget(id0), 'class', classes, batch1);
  ctx.addRoot(style);
  const attr4 = renderSsrAttr(createSsrElementTarget(id0), 'style', style, batch1);
  return (
    '<div q:id="' +
    id0 +
    '" title="' +
    escapeHTML(attr2) +
    '" class="' +
    escapeHTML(attr3) +
    '" style="' +
    escapeHTML(attr4) +
    '">Attrs</div>'
  );
}

