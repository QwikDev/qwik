import {
  createSignal,
  createSsrDomBatchEffect,
  createSsrElementTarget,
  escapeHTML,
  renderSsrAttr,
  renderSsrClass,
  renderSsrStyle,
} from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const title = createSignal('hello');
  const classes = createSignal('active');
  const style = createSignal('color:red');
  const id0 = ctx.nextId();
  ctx.addRoot(title);
  const batch1 = createSsrDomBatchEffect();
  const attr2 = renderSsrAttr(createSsrElementTarget(id0), 'title', title, batch1);
  ctx.addRoot(classes);
  const attr3 = renderSsrClass(createSsrElementTarget(id0), classes, batch1);
  ctx.addRoot(style);
  const attr4 = renderSsrStyle(createSsrElementTarget(id0), style, batch1);
  return (
    '<div q:id="' +
    id0 +
    '" title="' +
    escapeHTML(attr2) +
    '" class="' +
    escapeHTML(attr3) +
    '" style="' +
    escapeHTML(attr4) +
    '">Attrs</div>'
  );
}

