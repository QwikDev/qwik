import {
  createSignal,
  escapeHTML,
  createSsrElementTarget,
  renderSsrAttr,
  renderSsrClass,
  renderSsrStyle,
} from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const title = createSignal('hello');
  const classes = createSignal('active');
  const style = createSignal('color:red');
  const id0 = ctx.nextId();
  ctx.addRoot(title);
  ctx.addRoot(classes);
  ctx.addRoot(style);
  return (
    '<div q:id="' +
    id0 +
    '" title="' +
    escapeHTML(renderSsrAttr(createSsrElementTarget(id0), 'title', title)) +
    '" class="' +
    escapeHTML(renderSsrClass(createSsrElementTarget(id0), classes)) +
    '" style="' +
    escapeHTML(renderSsrStyle(createSsrElementTarget(id0), style)) +
    '">Attrs</div>'
  );
}

