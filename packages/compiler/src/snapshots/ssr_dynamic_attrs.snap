import {
  createSignal,
  createDomBatchEffect,
  readTrackedSourceValue,
  serializeAttrExpressionValue,
} from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const title = createSignal('hello');
  const classes = createSignal('active');
  const style = createSignal('color:red');
  const el0 = ctx.document.createElement('div');
  const effect1 = createDomBatchEffect(batch2, { scheduler: ctx.scheduler });
  const text3 = ctx.document.createTextNode('Attrs');
  el0.appendChild(text3);
  function batch2() {
    el0.setAttribute('title', String(readTrackedSourceValue(title)));
    el0.className = serializeAttrExpressionValue('class', readTrackedSourceValue(classes));
    el0.setAttribute('style', serializeAttrExpressionValue('style', readTrackedSourceValue(style)));
  }
  ctx.scheduler.notify(effect1);
  return [el0];
}

