import {
  createSignal,
  escapeHTML,
  renderSsrTextNode,
  createSsrRangeTextTarget,
} from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const count = createSignal(0);
  const id0 = ctx.nextId();
  ctx.addRoot(count);
  return (
    '<p q:id="' +
    id0 +
    '">Hello <!t>' +
    escapeHTML(renderSsrTextNode(createSsrRangeTextTarget(id0, 0), count)) +
    '<!/t> world</p>'
  );
}

