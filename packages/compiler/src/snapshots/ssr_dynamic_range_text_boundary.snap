import { createSignal, createTextNodeEffect } from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const count = createSignal(0);
  const el0 = ctx.document.createElement('p');
  const text1 = ctx.document.createTextNode('Hello ');
  el0.appendChild(text1);
  const text2 = ctx.document.createTextNode('');
  const effect3 = createTextNodeEffect(text2, count, { scheduler: ctx.scheduler });
  ctx.scheduler.notify(effect3);
  el0.appendChild(text2);
  const text4 = ctx.document.createTextNode(' world');
  el0.appendChild(text4);
  return [el0];
}

