import { createSignal, createTextNodeEffect } from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const first = createSignal(1);
  const second = createSignal(2);
  const el0 = ctx.document.createElement('p');
  const text1 = ctx.document.createTextNode('');
  const effect2 = createTextNodeEffect(text1, first, { scheduler: ctx.scheduler });
  ctx.scheduler.notify(effect2);
  el0.appendChild(text1);
  const text3 = ctx.document.createTextNode('');
  const effect4 = createTextNodeEffect(text3, second, { scheduler: ctx.scheduler });
  ctx.scheduler.notify(effect4);
  el0.appendChild(text3);
  return el0;
}

