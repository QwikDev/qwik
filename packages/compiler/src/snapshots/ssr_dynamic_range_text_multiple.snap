import { createSignal, createDomBatchEffect, readTrackedSourceValue } from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const first = createSignal(1);
  const second = createSignal(2);
  const el0 = ctx.document.createElement('p');
  const text1 = ctx.document.createTextNode('');
  const effect2 = createDomBatchEffect(batch3, { scheduler: ctx.scheduler });
  el0.appendChild(text1);
  const text4 = ctx.document.createTextNode('');
  el0.appendChild(text4);
  function batch3() {
    text1.data = String(readTrackedSourceValue(first));
    text4.data = String(readTrackedSourceValue(second));
  }
  ctx.scheduler.notify(effect2);
  return [el0];
}

