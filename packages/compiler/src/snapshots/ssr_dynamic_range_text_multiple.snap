import {
  createSignal,
  createSsrDomBatchEffect,
  escapeHTML,
  renderSsrTextNode,
  createSsrRangeTextTarget,
} from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const first = createSignal(1);
  const second = createSignal(2);
  const id0 = ctx.nextId();
  ctx.addRoot(first);
  const batch2 = createSsrDomBatchEffect();
  const text1 = renderSsrTextNode(createSsrRangeTextTarget(id0, 0), first, batch2);
  ctx.addRoot(second);
  const text3 = renderSsrTextNode(createSsrRangeTextTarget(id0, 1), second, batch2);
  return '<p q:id="' + id0 + '"><!t>' + escapeHTML(text1) + '<!t>' + escapeHTML(text3) + '</p>';
}

