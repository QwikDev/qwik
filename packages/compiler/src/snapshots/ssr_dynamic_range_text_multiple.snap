import {
  createSignal,
  escapeHTML,
  renderSsrTextNode,
  createSsrRangeTextTarget,
} from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const first = createSignal(1);
  const second = createSignal(2);
  const id0 = ctx.nextId();
  ctx.addRoot(first);
  ctx.addRoot(second);
  return (
    '<p q:id="' +
    id0 +
    '"><!t>' +
    escapeHTML(renderSsrTextNode(createSsrRangeTextTarget(id0, 0), first)) +
    '<!t>' +
    escapeHTML(renderSsrTextNode(createSsrRangeTextTarget(id0, 1), second)) +
    '</p>'
  );
}

