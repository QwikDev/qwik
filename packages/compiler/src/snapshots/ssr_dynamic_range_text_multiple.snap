import {
  createSignal,
  escapeHTML,
  renderSsrTextNode,
  createSsrRangeTextTarget,
} from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const first = createSignal(1);
  const second = createSignal(2);
  const id0 = ctx.nextId();
  ctx.addRoot(first);
  const text1 = renderSsrTextNode(createSsrRangeTextTarget(id0, 0), first);
  ctx.addRoot(second);
  const text2 = renderSsrTextNode(createSsrRangeTextTarget(id0, 1), second);
  return '<p q:id="' + id0 + '"><!t>' + escapeHTML(text1) + '<!t>' + escapeHTML(text2) + '</p>';
}

