export function App(_props, ctx) {
  const el0 = ctx.document.createElement('main');
  el0.className = 'shell';
  el0.setAttribute('hidden', '');
  const el1 = ctx.document.createElement('h1');
  const text2 = ctx.document.createTextNode('Hello');
  el1.appendChild(text2);
  el0.appendChild(el1);
  const el3 = ctx.document.createElement('p');
  const text4 = ctx.document.createTextNode('Qwik');
  el3.appendChild(text4);
  el0.appendChild(el3);
  return [el0];
}

