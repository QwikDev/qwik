import { createContextId } from '@qwik.dev/core';
import {
  createContextProvider,
  createSignal,
  escapeHTML,
  renderSsrTextNode,
  createSsrElementTextTarget,
} from '@qwik.dev/core/spark';

export const App = (_props, ctx) => {
  const contextId = createContextId('context');
  const source = createSignal('hello');
  createContextProvider(contextId, source);
  const contextScopeId = ctx.contextScopeId();
  const id0 = ctx.nextId();
  ctx.addRoot(source);
  const contextHtml =
    '<p q:id="' +
    id0 +
    '">' +
    escapeHTML(renderSsrTextNode(createSsrElementTextTarget(id0), source)) +
    '</p>';
  return '<!c=' + contextScopeId + '>' + contextHtml + '<!/c>';
};

