import {
  useContextProvider,
  useSignal,
  escapeHTML,
  renderSsrTextNode,
  createSsrElementTextTarget,
  maybeThen,
} from '@qwik.dev/core/spark';

export const App = (_props, ctx) => {
  const contextId = createContextId('context');
  const source = useSignal('hello');
  useContextProvider(contextId, source);
  const contextScopeId = ctx.contextScopeId();
  const id0 = ctx.nextId();
  ctx.addRoot(source);
  const text1 = renderSsrTextNode(createSsrElementTextTarget(id0), source);
  return maybeThen(
    text1,
    (text1) =>
      '<!c=' +
      contextScopeId +
      '>' +
      '<p q:id="' +
      id0 +
      '">' +
      escapeHTML(text1) +
