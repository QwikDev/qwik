import { createContextId } from '@qwik.dev/core';
import { createContextProvider, createSignal, createTextNodeEffect } from '@qwik.dev/core/spark';

export const App = (_props, ctx) => {
  const contextId = createContextId('context');
  const source = createSignal('hello');
  createContextProvider(contextId, source);
  const el0 = ctx.document.createElement('p');
  const text1 = ctx.document.createTextNode('');
  const effect2 = createTextNodeEffect(text1, source, { scheduler: ctx.scheduler });
  ctx.scheduler.notify(effect2);
  el0.appendChild(text1);
  return [el0];
};

