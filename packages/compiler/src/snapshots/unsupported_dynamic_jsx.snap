import { createSignal, createTextExpressionEffect } from '@qwik.dev/core/spark';

export function App(_props, ctx) {
  const count = createSignal(0);
  const el0 = ctx.document.createElement('p');
  const text1 = ctx.document.createTextNode('');
  const effect2 = createTextExpressionEffect(text1, [], () => count.value, {
    scheduler: ctx.scheduler,
  });
  ctx.scheduler.notify(effect2);
  el0.appendChild(text1);
  return [el0];
}

