export const buildHead = ({ ogImage })=>{
    for ({ ogImage } of [
        {
            ogImage: "fallback-image-url"
        }
    ]);
    return {
        meta: [
            {
                property: "og:image",
                content: ogImage
            }
        ]
    };
};


