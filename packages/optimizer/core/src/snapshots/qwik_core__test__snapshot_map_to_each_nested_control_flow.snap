==INPUT==


import { component$ } from '@qwik.dev/core';

export const App = component$(() => {
  const items = [{ id: 'a', altId: 'b', vip: true, name: 'A' }];
  return <div>{items.map((item, idx) => {
    let label = item.name;
    if (item.vip) {
      label = label + ':' + idx;
    }

    let key = item.id;
    if (item.altId) {
      key = item.altId;
    }

    return <article key={key}>{label}</article>;
  })}</div>;
});

