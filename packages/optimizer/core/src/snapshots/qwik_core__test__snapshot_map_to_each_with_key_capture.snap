import { component$ } from '@qwik.dev/core';

export const App = component$(() => {
  const items = [{ id: 'a', text: 'A' }];
  const prefix = { value: 'item:' };
  return <div>{items.map((item) => <span key={prefix.value + item.id}>{item.text}</span>)}</div>;
});

