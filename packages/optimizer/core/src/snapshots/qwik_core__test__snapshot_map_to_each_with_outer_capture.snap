import { component$ } from '@qwik.dev/core';

export const App = component$(() => {
  const items = [{ id: 'a', text: 'A' }];
  const extra = { suffix: '!' };
  return <div>{items.map((item) => <span key={item.id}>{item.text + extra.suffix}</span>)}</div>;
});

