{
  "name": "qwik-optimizer-ts",
  "version": "0.0.1",
  "type": "module",
  "description": "A TypeScript implementation of the Qwik optimizer.",
  "keywords": [
    "qwik",
    "optimizer",
    "qrl",
    "oxc",
    "bundler",
    "ast"
  ],
  "license": "MIT",
  "homepage": "https://github.com/thejackshelton/TS-Optimizer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thejackshelton/TS-Optimizer.git"
  },
  "bugs": {
    "url": "https://github.com/thejackshelton/TS-Optimizer/issues"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test",
    "ci:baseline:check": "node scripts/check-regression.mjs",
    "ci:baseline:update": "node scripts/update-baseline.mjs"
  },
  "dependencies": {
    "@oxc-project/types": "0.124.0",
    "magic-regexp": "^0.11.0",
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.124.0",
    "oxc-transform": "^0.124.0",
    "oxc-walker": "^0.7.0",
    "pathe": "^2.0.3",
    "siphash": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "fast-deep-equal": "^3.1.3",
    "tsdown": "^0.22.3",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
