{
  "name": "qwik-optimizer-ts",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "ci:baseline:check": "node scripts/check-regression.mjs",
    "ci:baseline:update": "node scripts/update-baseline.mjs"
  },
  "dependencies": {
    "@oxc-project/types": "0.124.0",
    "magic-regexp": "^0.11.0",
    "magic-string": "^0.30.21",
    "pathe": "^2.0.3",
    "siphash": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "fast-deep-equal": "^3.1.3",
    "oxc-parser": "^0.124.0",
    "oxc-transform": "^0.124.0",
    "oxc-walker": "^0.7.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
