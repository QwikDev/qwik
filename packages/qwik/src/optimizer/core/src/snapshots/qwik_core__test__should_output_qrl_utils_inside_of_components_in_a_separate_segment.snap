import { $, component$, useSignal, useTask$ } from '@qwik.dev/core';

export const TestButton = component$(() => {
	const testLogger = $(() => {
		console.log("testLogger");
	});

	testLogger();
	const sig = useSignal(0);

	useTask$(() => {
		console.log("log 1:", testLogger());
	});

	useTask$(() => {
		console.log("log 2:", testLogger());
	});

	return (
		<>
		<button
			onClick$={() => {
			testLogger();
			sig.value++;
			}}
		>
			{sig.value}
		</button>
		</>
	);
});

